{
	"format_version": "1.8.0",
	"animations": {
		"animation.tractor.idle": {
			"loop": true,
			"bones": {
				"body": {
					"position": {
						"0.0": [0, 0, 0],
						"1.0": [0, 0.2, 0],
						"2.0": [0, 0, 0]
					}
				}
			}
		},
		"animation.tractor.move": {
			"loop": true,
			"bones": {
				"wheel_fl": { "rotation": ["-query.anim_time * 500", 0, 0] },
				"wheel_fr": { "rotation": ["-query.anim_time * 500", 0, 0] },
				"wheel_rl": { "rotation": ["-query.anim_time * 500", 0, 0] },
				"wheel_rr": { "rotation": ["-query.anim_time * 500", 0, 0] }
			}
		}
	}
}
